rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /faculty/{facultyId} {
      allow read, write: if true;
    }

    match /teams/{teamId} {
      allow read, write: if true;
    }

    match /pending_allocations/{pendingId} {
      allow read, write: if true;
    }

    match /metadata/{docId} {
      allow read, write: if true;
    }
  }
}
